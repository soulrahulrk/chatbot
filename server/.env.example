# Port the Express/Socket.io server listens on
PORT=5000

# MongoDB Atlas connection string (see README.md "MongoDB Atlas setup")
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/realtime-chat?retryWrites=true&w=majority

# Origin allowed to call the API / connect via Socket.io (your frontend URL)
CLIENT_URL=http://localhost:5173

# development | production
NODE_ENV=development
